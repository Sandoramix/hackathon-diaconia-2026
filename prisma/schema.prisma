generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

enum UserRole {
  STUDENTE
  TUTOR
  ADMIN
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Structure ────────────────────────────────────────────────────────────────

model Structure {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rules              Rule[]
  users              User[]
  events             Event[]
  tasks              Task[]
  conversations      Conversation[]
  activityNotes      StudentActivityNote[]
  alarms             StudentAlarm[]
  broadcasts         Broadcast[]

  @@index([name])
}

model Rule {
  id          String    @id @default(cuid())
  icon        String
  text        String
  order       Int       @default(0)
  structureId String
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade)
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String?
  username           String    @unique
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  password           String?   @db.Text
  role               UserRole  @default(STUDENTE)
  mustChangePassword Boolean   @default(false)
  notes              String?   @db.Text
  familyContacts     String?   @db.Text
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())

  structureId String?
  structure   Structure? @relation(fields: [structureId], references: [id])

  createdById  String?
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]  @relation("UserCreatedBy")

  accounts Account[]
  sessions Session[]

  eventParticipations   EventParticipant[]
  taskSlotOccupations   TaskSlotOccupation[]
  taskCompletions       TaskCompletion[]
  feedbacks             Feedback[]
  sentMessages          ChatMessage[]             @relation("ChatMessageSender")
  studentConversations  Conversation[]            @relation("ConversationStudent")
  tutorConversations    Conversation[]            @relation("ConversationTutor")
  activityNotesGiven    StudentActivityNote[]     @relation("TutorActivityNotes")
  activityNotesReceived StudentActivityNote[]     @relation("StudentActivityNotes")
  alarmsReceived        StudentAlarm[]            @relation("StudentAlarms")
  broadcastsGiven       Broadcast[]               @relation("BroadcastAuthor")
  broadcastReads        BroadcastRead[]           @relation("BroadcastReads")
}

// ─── Event ────────────────────────────────────────────────────────────────────

model EventTag {
  id     String  @id @default(cuid())
  name   String  @unique
  events Event[]
  tasks  Task[]

  @@index([name])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  place       String?
  startDate   DateTime
  endDate     DateTime
  image       String?
  userLimit   Int?
  hasFeedback Boolean  @default(false)

  structureId String
  structure   Structure @relation(fields: [structureId], references: [id])

  tags         EventTag[]
  participants EventParticipant[]
  feedbacks    Feedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
}

model EventParticipant {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ─── Task ─────────────────────────────────────────────────────────────────────

enum TaskType {
  OCCASIONAL
  RECURRENT
}

model Task {
  id                String   @id @default(cuid())
  title             String
  description       String?  @db.Text
  image             String?  @db.Text
  type              TaskType @default(OCCASIONAL)
  hasFeedback       Boolean  @default(false)
  isCompletable     Boolean  @default(false)
  recurrenceDays    Int[]    @default([])
  recurrenceWeeks   Int      @default(4)
  windowStart       String?
  windowEnd         String?
  slotDurationHours Float?

  structureId String
  structure   Structure @relation(fields: [structureId], references: [id])

  slots       TaskSlot[]
  feedbacks   Feedback[]
  completions TaskCompletion[]
  tags        EventTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  completedAt DateTime @default(now())

  @@unique([taskId, userId])
}

model TaskSlot {
  id           String    @id @default(cuid())
  taskId       String
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  date         DateTime
  slotStart    DateTime?
  slotEnd      DateTime?
  maxOccupants Int       @default(1)

  occupations TaskSlotOccupation[]

  @@index([date])
}

enum OccupationAction {
  SUBSCRIBED
  UNSUBSCRIBED
}

// Log of every sub/unsub event. isActive=true means this is the current active subscription.
// Only one record per (slotId, userId) can have isActive=true.
model TaskSlotOccupation {
  id        String           @id @default(cuid())
  slotId    String
  slot      TaskSlot         @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  action    OccupationAction
  isActive  Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([slotId, isActive])
  @@index([slotId, userId, createdAt])
}

// ─── Feedback ─────────────────────────────────────────────────────────────────

// emoji: 1 | 2 | 3  (validated at app level)
model Feedback {
  id    String  @id @default(cuid())
  emoji Int
  text  String? @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id])

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])
  taskId  String?
  task    Task?   @relation(fields: [taskId], references: [id])

  createdAt DateTime @default(now())

  // PostgreSQL: NULL != NULL so these constraints only fire when the FK is set
  @@unique([userId, eventId])
  @@unique([userId, taskId])
}

// ─── Activity Notes ───────────────────────────────────────────────────────────

model StudentActivityNote {
  id          String    @id @default(cuid())
  content     String    @db.Text
  tutorId     String
  tutor       User      @relation("TutorActivityNotes", fields: [tutorId], references: [id])
  studentId   String
  student     User      @relation("StudentActivityNotes", fields: [studentId], references: [id])
  structureId String
  structure   Structure @relation(fields: [structureId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([studentId, createdAt])
}

// ─── Alarms ───────────────────────────────────────────────────────────────────

enum AlarmType {
  INACTIVE
  HIGH_ABANDONMENT
  LOW_EVENT_PARTICIPATION
}

enum AlarmSeverity {
  LOW
  MEDIUM
  HIGH
}

model StudentAlarm {
  id           String        @id @default(cuid())
  studentId    String
  student      User          @relation("StudentAlarms", fields: [studentId], references: [id])
  structureId  String
  structure    Structure     @relation(fields: [structureId], references: [id])
  type         AlarmType
  severity     AlarmSeverity
  message      String        @db.Text
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([studentId, resolvedAt])
  @@index([structureId, resolvedAt])
}

// ─── Broadcast ────────────────────────────────────────────────────────────────

model Broadcast {
  id          String          @id @default(cuid())
  title       String
  body        String          @db.Text
  authorId    String
  author      User            @relation("BroadcastAuthor", fields: [authorId], references: [id])
  structureId String
  structure   Structure       @relation(fields: [structureId], references: [id])
  createdAt   DateTime        @default(now())
  reads       BroadcastRead[]

  @@index([structureId, createdAt])
}

model BroadcastRead {
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("BroadcastReads", fields: [studentId], references: [id])
  readAt      DateTime  @default(now())

  @@id([broadcastId, studentId])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Conversation {
  id          String        @id @default(cuid())
  studentId   String
  student     User          @relation("ConversationStudent", fields: [studentId], references: [id])
  tutorId     String
  tutor       User          @relation("ConversationTutor", fields: [tutorId], references: [id])
  structureId String
  structure   Structure     @relation(fields: [structureId], references: [id])
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([studentId, tutorId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("ChatMessageSender", fields: [senderId], references: [id])
  text           String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())
}
